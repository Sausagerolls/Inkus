<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDevelopmentRegion</key>
    <string>$(DEVELOPMENT_LANGUAGE)</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>$(PRODUCT_NAME)</string>
    <key>CFBundleDisplayName</key>
    <string>Inkus</string>

    <!-- Mac App Store requires this. UTI for the Lifestyle category. -->
    <key>LSApplicationCategoryType</key>
    <string>public.app-category.lifestyle</string>

    <!-- Export-compliance exemption. Inkus uses only Apple's OS-provided
         encryption (URLSession HTTPS, Keychain, CryptoKit SHA-256 for PKCE
         code challenge). No proprietary or third-party crypto. Falsifies
         the "App Encryption Documentation" question on every upload. -->
    <key>ITSAppUsesNonExemptEncryption</key>
    <false/>

    <key>CFBundlePackageType</key>
    <string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
    <key>CFBundleShortVersionString</key>
    <string>$(MARKETING_VERSION)</string>
    <key>CFBundleVersion</key>
    <string>$(CURRENT_PROJECT_VERSION)</string>
    <key>LSRequiresIPhoneOS</key>
    <true/>

    <!-- URL types — required for OAuth callback and brand-specific Google scheme. -->
    <key>CFBundleURLTypes</key>
    <array>
        <dict>
            <key>CFBundleTypeRole</key>
            <string>Editor</string>
            <key>CFBundleURLName</key>
            <string>com.giantmushroom.Inkus.oauth</string>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>inkus</string>
            </array>
        </dict>
        <dict>
            <key>CFBundleTypeRole</key>
            <string>Editor</string>
            <key>CFBundleURLName</key>
            <string>com.giantmushroom.Inkus.google</string>
            <key>CFBundleURLSchemes</key>
            <array>
                <!-- Replace with your Google client ID's reverse-DNS form, e.g.
                     com.googleusercontent.apps.123456-abcdefg
                     after creating an iOS OAuth client in Google Cloud Console. -->
                <string>$(INKUS_GOOGLE_REVERSE_CLIENT_ID)</string>
            </array>
        </dict>
    </array>

    <!-- OAuth client identifiers, exposed to the app via Bundle.main.object(forInfoDictionaryKey:).
         Both are public values for native PKCE clients. Set them via xcconfig or directly here. -->
    <key>INKUS_DROPBOX_APP_KEY</key>
    <string>$(INKUS_DROPBOX_APP_KEY)</string>
    <key>INKUS_GOOGLE_CLIENT_ID</key>
    <string>$(INKUS_GOOGLE_CLIENT_ID)</string>

    <!-- Background modes for CloudKit push delivery. -->
    <key>UIBackgroundModes</key>
    <array>
        <string>remote-notification</string>
    </array>

    <key>UIApplicationSceneManifest</key>
    <dict>
        <key>UIApplicationSupportsMultipleScenes</key>
        <true/>
    </dict>
    <key>UIApplicationSupportsIndirectInputEvents</key>
    <true/>
    <key>UILaunchScreen</key>
    <dict/>
    <key>UIStatusBarStyle</key>
    <string>UIStatusBarStyleDefault</string>

    <key>UISupportedInterfaceOrientations~iphone</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>
    <key>UISupportedInterfaceOrientations~ipad</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationPortraitUpsideDown</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>

    <!-- Permission strings — describe what the app actually does with each capability. -->
    <key>NSPhotoLibraryUsageDescription</key>
    <string>Inkus can attach photos from your library to a journal entry. Photos stay on this device unless you opt in to a cloud provider in Settings.</string>
    <key>NSCameraUsageDescription</key>
    <string>Inkus uses the camera to scan documents into your journal entries. Scans stay on this device unless you opt in to a cloud provider in Settings.</string>
    <key>NSMicrophoneUsageDescription</key>
    <string>Inkus records voice notes when you tap the microphone in the editor. Recordings save as audio attachments alongside the entry.</string>
    <key>NSSpeechRecognitionUsageDescription</key>
    <string>Inkus transcribes voice notes and handwritten input on this device using Apple's Speech and Vision frameworks. No audio or text is sent to a server.</string>
</dict>
</plist>
